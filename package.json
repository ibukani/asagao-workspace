{
  "name": "asagao-workspace",
  "version": "1.0.0",
  "private": true,
  "description": "Minimal ChatGPT App scaffold using the OpenAI Apps SDK and MCP.",
  "main": "server.js",
  "type": "module",
  "scripts": {
    "start": "node --experimental-strip-types server.js",
    "dev": "node --experimental-strip-types --watch server.js",
    "check": "node --experimental-strip-types scripts/check-syntax.ts",
    "typecheck": "tsc --noEmit",
    "test": "node --experimental-strip-types --test \"tests/**/*.test.ts\"",
    "verify": "npm run check && npm run typecheck && npm test",
    "inspect": "npx @modelcontextprotocol/inspector@latest --server-url http://localhost:8787/mcp --transport http"
  },
  "engines": {
    "node": ">=22"
  },
  "license": "ISC",
  "dependencies": {
    "@modelcontextprotocol/ext-apps": "^1.7.4",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "execa": "^9.6.1",
    "fast-glob": "^3.3.3",
    "ignore": "^7.0.5",
    "p-queue": "^9.3.0",
    "pino": "^10.3.1",
    "yazl": "^3.3.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "typescript": "^5.9.3"
  }
}
